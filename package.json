{
  "name": "opsx-ui",
  "version": "0.1.0",
  "description": "A read-only, live-updating web viewer for everything OpenSpec touches.",
  "type": "module",
  "bin": {
    "opsx-ui": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:web": "vite",
    "dev:server": "tsx watch src/cli/index.ts",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.node.json",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "open": "^10.1.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
